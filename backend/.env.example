# Environment variables for TradeX Backend
# Copy this to .env and fill in your values

# ── Supabase ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── JWT (for admin panel auth) ──
JWT_SECRET=generate-a-strong-random-uuid-here
JWT_EXPIRES_IN=24h

# ── Server ──
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
LANDING_URL=http://localhost:5175

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Market Data Feeds ──
# Finnhub (FREE — sign up at https://finnhub.io)
# Covers: Indian Stocks, US Stocks, Forex, Commodities, Indices
FINNHUB_API_KEY=your_finnhub_api_key_here

# Binance — NO KEY NEEDED (free public WebSocket for crypto)

# Shoonya (Finvasia) Feed API Configuration
# Required for real-time 0-lag Indian market data (Equities, Indices, F&O)
SHOONYA_USER_ID=your_shoonya_user_id
SHOONYA_PASSWORD=your_shoonya_password
SHOONYA_API_KEY=your_shoonya_api_key
SHOONYA_TOTP_SECRET=your_shoonya_totp_secret
SHOONYA_VENDOR_CODE=your_shoonya_vendor_code

# ── Error Monitoring ──
SENTRY_DSN=your_sentry_dsn_url

# ── Redis ──
REDIS_URL=your_redis_url

